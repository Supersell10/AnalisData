    "# 1. Постановка задачи\n",
    "\n",
    "## Описание датасета\n",
    "\n",
    "Датасет содержит информацию об автомобилях различных марок и моделей. В набор данных входят технические характеристики автомобилей, тип топлива, пробег, мощность двигателя, стоимость автомобиля и другие параметры."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "\n",
    "from faker import Faker\n",
    "import random\n",
    "\n",
    "plt.style.use('ggplot')\n",
    "sns.set(font_scale=1)\n",
    "\n",
    "fake = Faker()\n",
    "\n",
    "np.random.seed(42)\n",
    "random.seed(42)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Генерация датасета"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "brands_models = {\n",
    "    'Toyota': ['Corolla', 'Camry', 'RAV4'],\n",
    "    'BMW': ['X5', '320', '520'],\n",
    "    'Mercedes': ['C200', 'E200', 'GLA'],\n",
    "    'Audi': ['A4', 'A6', 'Q5'],\n",
    "    'Volkswagen': ['Golf', 'Passat', 'Tiguan'],\n",
    "    'Ford': ['Focus', 'Mondeo', 'Explorer'],\n",
    "    'Kia': ['Rio', 'Sportage', 'Cerato'],\n",
    "    'Hyundai': ['Solaris', 'Tucson', 'Elantra']\n",
    "}\n",
    "\n",
    "fuel_types = ['Petrol', 'Diesel', 'Hybrid', 'Electric']\n",
    "transmissions = ['Manual', 'Automatic']\n",
    "colors = ['Black', 'White', 'Silver', 'Blue', 'Red', 'Gray']\n",
    "\n",
    "rows = []\n",
    "\n",
    "for i in range(1000):\n",
    "    brand = random.choice(list(brands_models.keys()))\n",
    "    model = random.choice(brands_models[brand])\n",
    "    year = random.randint(2005, 2024)\n",
    "    fuel = random.choice(fuel_types)\n",
    "    transmission = random.choice(transmissions)\n",
    "\n",
    "    mileage = max(0, int(np.random.normal(120000, 50000)))\n",
    "    engine_volume = round(np.random.uniform(1.0, 5.0), 1)\n",
    "    horsepower = int(engine_volume * np.random.uniform(70, 120))\n",
    "\n",
    "    base_price = (\n",
    "        300000\n",
    "        + horsepower * 4000\n",
    "        + (year - 2005) * 25000\n",
    "    )\n",
    "\n",
    "    price = int(np.random.normal(base_price, 150000))\n",
    "    price = max(price, 200000)\n",
    "\n",
    "    color = random.choice(colors)\n",
    "    owners = random.randint(1, 5)\n",
    "\n",
    "    registration_date = fake.date_between(\n",
    "        start_date='-15y',\n",
    "        end_date='today'\n",
    "    )\n",
    "\n",
    "    rows.append([\n",
    "        i + 1,\n",
    "        brand,\n",
    "        model,\n",
    "        year,\n",
    "        fuel,\n",
    "        transmission,\n",
    "        mileage,\n",
    "        engine_volume,\n",
    "        horsepower,\n",
    "        price,\n",
    "        color,\n",
    "        owners,\n",
    "        registration_date\n",
    "    ])\n",
    "\n",
    "columns = [\n",
    "    'car_id',\n",
    "    'brand',\n",
    "    'model',\n",
    "    'year',\n",
    "    'fuel_type',\n",
    "    'transmission',\n",
    "    'mileage',\n",
    "    'engine_volume',\n",
    "    'horsepower',\n",
    "    'price',\n",
    "    'color',\n",
    "    'owners',\n",
    "    'registration_date'\n",
    "]\n",
    "\n",
    "df = pd.DataFrame(rows, columns=columns)"
   ]
  }
 ],
